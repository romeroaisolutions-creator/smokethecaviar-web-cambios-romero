# Mercado Pago — obtén tus credenciales en https://www.mercadopago.com/developers
# Usa el Access Token de PRODUCCION para cobros reales,
# o el de TEST para pruebas sin dinero real.
MP_ACCESS_TOKEN=APP_USR-...tu-access-token-aqui...

# URL pública de tu sitio (sin barra al final)
# En Vercel se completa automáticamente con VERCEL_URL
APP_URL=https://tu-sitio.vercel.app

# Moneda ISO 4217: ARS (Argentina), MXN (México), COP (Colombia), CLP (Chile), etc.
MP_CURRENCY_ID=ARS
